{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@mohak34/opencode-notifier@latest"],
  "agent": {
    "explore": {
      "model": "github-copilot/claude-haiku-4.5"
    },
    "title": {
      "model": "github-copilot/gpt-5-mini"
    },
    "summary": {
      "model": "github-copilot/gpt-5-mini"
    },
    "compaction": {
      "model": "github-copilot/claude-haiku-4.5"
    },
    "general": {
      "model": "github-copilot/claude-sonnet-4.6"
    }
  },
  "permission": {
    "external_directory": {
      "/tmp/**": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-95ec39b0-f34e-40e0-87f4-101b74005f87"
      }
    },
    "shopify-dev-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@shopify/dev-mcp@latest"],
      "enabled": false
    }
  },
  "instructions": ["/home/jose/.config/opencode/rules/*.md"]
}
